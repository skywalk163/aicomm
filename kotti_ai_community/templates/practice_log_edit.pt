<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="api.macro('kotti:templates/view/master.pt')">

<tal:block metal:fill-slot="content">
<div class="practice-log-edit-page" style="max-width: 800px; margin: 0 auto; padding: 24px;">
    <h1>Edit Practice Log</h1>

    <form method="POST" class="form-horizontal">
        <input type="hidden" name="csrf_token" value="${python: request.session.get('csrf_token', '')}"/>
        
        <div class="panel panel-default" style="margin-bottom: 20px; padding: 20px; background: white; border-radius: 8px;">
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Title</label>
                <input type="text" name="title" value="${context/title}" class="form-control" 
                       style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" required/>
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Content</label>
                <textarea name="content" rows="6" class="form-control" 
                          style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"
                          tal:content="context/content">Content</textarea>
            </div>

            <div class="row" style="display: flex; gap: 20px; margin-bottom: 15px;">
                <div style="flex: 1;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px;">Log Type</label>
                    <select name="log_type" class="form-control" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                        <tal:block tal:repeat="lt log_types">
                            <option tal:attributes="value lt; selected python: 'selected' if lt == context.log_type else None"
                                    tal:content="python: log_types[lt]">Type</option>
                        </tal:block>
                    </select>
                </div>
                <div style="flex: 1;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px;">Visibility</label>
                    <select name="visibility" class="form-control" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                        <tal:block tal:repeat="lv log_visibility">
                            <option tal:attributes="value lv; selected python: 'selected' if lv == context.visibility else None"
                                    tal:content="python: log_visibility[lv]">Visibility</option>
                        </tal:block>
                    </select>
                </div>
                <div style="flex: 1;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px;">Time Spent (minutes)</label>
                    <input type="number" name="time_spent" value="${context/time_spent}" class="form-control" 
                           style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" min="0"/>
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Tags (comma-separated, max 10)</label>
                <input type="text" name="tags" value="${python: ', '.join(context.tags or [])}" class="form-control" 
                       style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"
                       placeholder="progress, milestone, learning"/>
            </div>
        </div>

        <div style="display: flex; gap: 10px;">
            <button type="submit" class="btn btn-primary" style="background: #667eea; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer;">
                Save Changes
            </button>
            <a tal:attributes="href python: request.resource_url(context)" class="btn btn-default" 
               style="background: #6c757d; color: white; padding: 10px 20px; border-radius: 4px; text-decoration: none;">
                Cancel
            </a>
        </div>
    </form>
</div>
</tal:block>

</html>
