<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="api.macro('kotti:templates/view/master.pt')">

<tal:block metal:fill-slot="content">
<div class="milestone-add-page" style="max-width: 600px; margin: 0 auto; padding: 24px;">
    <h1 style="margin-bottom: 8px;">Add Milestone</h1>
    <p style="color: #666; margin-bottom: 24px;">
        Project: <a href="${request/resource_url(context)}" style="color: #667eea;">${context/title}</a>
    </p>

    <form method="POST" action="" style="background: white; border-radius: 12px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <!-- Title -->
        <div style="margin-bottom: 20px;">
            <label style="display: block; font-weight: bold; margin-bottom: 8px;">Milestone Title *</label>
            <input type="text" name="title" required
                   placeholder="e.g., MVP Release, Beta Testing, Launch"
                   style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px;"/>
        </div>

        <!-- Description -->
        <div style="margin-bottom: 20px;">
            <label style="display: block; font-weight: bold; margin-bottom: 8px;">Description</label>
            <textarea name="description" rows="4"
                      placeholder="What does this milestone represent? What needs to be achieved?"
                      style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px; resize: vertical;"></textarea>
        </div>

        <!-- Target Date -->
        <div style="margin-bottom: 20px;">
            <label style="display: block; font-weight: bold; margin-bottom: 8px;">Target Date</label>
            <input type="date" name="target_date"
                   style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px;"/>
            <p style="color: #666; font-size: 14px; margin-top: 4px;">When do you plan to complete this milestone?</p>
        </div>

        <!-- Submit -->
        <div style="margin-top: 24px;">
            <button type="submit" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 14px 32px; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer;">
                Add Milestone
            </button>
            <a href="${request/resource_url(context)}/@@milestones" style="margin-left: 16px; color: #666;">Cancel</a>
        </div>
    </form>
</div>
</tal:block>

</html>
