<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="api.macro('kotti:templates/view/master.pt')">

<tal:block metal:fill-slot="content">
<div class="resource-edit-page" style="max-width: 800px; margin: 0 auto; padding: 24px;">
    <h1>Edit Resource</h1>

    <form method="POST" class="form-horizontal">
        <input type="hidden" name="csrf_token" value="${python: request.session.get('csrf_token', '')}"/>
        
        <div class="panel panel-default" style="margin-bottom: 20px; padding: 20px; background: white; border-radius: 8px;">
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Title</label>
                <input type="text" name="title" value="${context/title}" class="form-control" 
                       style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;" required/>
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Description</label>
                <textarea name="description" rows="4" class="form-control" 
                          style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"
                          tal:content="context/description">Description</textarea>
            </div>

            <div class="row" style="display: flex; gap: 20px; margin-bottom: 15px;">
                <div style="flex: 1;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px;">Category</label>
                    <select name="category" class="form-control" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                        <tal:block tal:repeat="cat categories">
                            <option tal:attributes="value cat; selected python: 'selected' if cat == context.category else None"
                                    tal:content="python: categories[cat]">Category</option>
                        </tal:block>
                    </select>
                </div>
                <div style="flex: 1;">
                    <label style="display: block; font-weight: bold; margin-bottom: 5px;">Access Type</label>
                    <select name="access_type" class="form-control" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;">
                        <tal:block tal:repeat="at access_types">
                            <option tal:attributes="value at; selected python: 'selected' if at == context.access_type else None"
                                    tal:content="python: access_types[at]">Access Type</option>
                        </tal:block>
                    </select>
                </div>
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">URL</label>
                <input type="url" name="url" value="${context/url}" class="form-control" 
                       style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"
                       placeholder="https://..."/>
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Usage Guide</label>
                <textarea name="usage_guide" rows="3" class="form-control" 
                          style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"
                          tal:content="context/usage_guide">Guide</textarea>
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Limitations</label>
                <textarea name="limitations" rows="3" class="form-control" 
                          style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"
                          tal:content="context/limitations">Limitations</textarea>
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px;">Tags (comma-separated, max 10)</label>
                <input type="text" name="tags" value="${python: ', '.join(context.tags or [])}" class="form-control" 
                       style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;"
                       placeholder="AI, model, dataset"/>
            </div>
        </div>

        <div style="display: flex; gap: 10px;">
            <button type="submit" class="btn btn-primary" style="background: #667eea; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer;">
                Save Changes
            </button>
            <a tal:attributes="href python: request.resource_url(context)" class="btn btn-default" 
               style="background: #6c757d; color: white; padding: 10px 20px; border-radius: 4px; text-decoration: none;">
                Cancel
            </a>
        </div>
    </form>
</div>
</tal:block>

</html>
