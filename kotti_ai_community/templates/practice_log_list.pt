<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="api.macro('kotti:templates/view/master.pt')">

<tal:block metal:fill-slot="content">
<div class="practice-log-list-page" style="max-width: 1200px; margin: 0 auto; padding: 24px;">
    <!-- Header -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h1 style="margin: 0;">
                <a href="${request/resource_url(context)}" style="color: inherit; text-decoration: none;">${context/title}</a>
            </h1>
            <p style="color: #666; margin: 8px 0 0 0;">Practice Logs and Progress</p>
        </div>
        <a href="${request/resource_url(context)}/@@add_log" class="btn" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: bold;">
            Add Log Entry
        </a>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 300px; gap: 24px;">
        <!-- Logs List -->
        <div>
            <!-- Filter -->
            <div style="background: white; border-radius: 12px; padding: 16px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                <form method="GET" action="" style="display: flex; gap: 12px; align-items: center;">
                    <label>Filter by type:</label>
                    <select name="log_type" style="padding: 8px 12px; border: 1px solid #ddd; border-radius: 6px;">
                        <option value="">All Types</option>
                        <tal:block tal:repeat="lt python: ['progress', 'milestone', 'achievement', 'blocker', 'learning', 'decision']">
                            <option tal:attributes="value lt; selected python: log_type_filter == lt" tal:content="python: log_types.get(lt, lt)">Type</option>
                        </tal:block>
                    </select>
                    <button type="submit" style="background: #667eea; color: white; padding: 8px 16px; border: none; border-radius: 6px; cursor: pointer;">Filter</button>
                </form>
            </div>

            <!-- Logs Timeline -->
            <div style="display: flex; flex-direction: column; gap: 16px;">
                <tal:block tal:repeat="log logs">
                    <div style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid;"
                         tal:attributes="style python: 'border-left-color: ' + {'progress': '#667eea', 'milestone': '#ffd700', 'achievement': '#28a745', 'blocker': '#dc3545', 'learning': '#17a2b8', 'decision': '#6c757d', 'other': '#999'}.get(log.log_type, '#999')">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px;">
                            <div>
                                <span style="background: #f0f0f0; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 500;" tal:content="log/get_log_type_display">Type</span>
                                <h3 style="margin: 8px 0 0 0;" tal:content="log/title">Log Title</h3>
                            </div>
                            <div style="text-align: right; color: #666; font-size: 14px;">
                                <div tal:define="from datetime import datetime; ts python: datetime.fromtimestamp(log.log_date) if log.log_date else None">
                                    <span tal:content="python: ts.strftime('%Y-%m-%d') if ts else ''">Date</span>
                                </div>
                            </div>
                        </div>

                        <p style="color: #666; margin: 0 0 12px 0; line-height: 1.6;"
                           tal:content="python: log.content[:300] + '...' if log.content and len(log.content) > 300 else (log.content or '')">
                            Content
                        </p>

                        <!-- Progress and Time -->
                        <div style="display: flex; gap: 16px; font-size: 14px; color: #666;">
                            <tal:block tal:condition="python: log.progress_change != 0">
                                <span style="color: ${python: '#28a745' if log.progress_change > 0 else '#dc3545'};">
                                    Progress: ${python: '+' + str(log.progress_change) if log.progress_change > 0 else str(log.progress_change)}%
                                </span>
                            </tal:block>
                            <tal:block tal:condition="python: log.time_spent > 0">
                                <span>Time: ${log/time_spent}h</span>
                            </tal:block>
                            <tal:block tal:condition="log/tags">
                                <span tal:repeat="tag log/tags" style="background: #e3f2fd; color: #1976d2; padding: 2px 8px; border-radius: 12px; font-size: 12px; margin-right: 4px;" tal:content="tag">Tag</span>
                            </tal:block>
                        </div>
                    </div>
                </tal:block>
            </div>

            <!-- Empty State -->
            <div tal:condition="not:logs" style="text-align: center; padding: 60px 20px; background: white; border-radius: 12px;">
                <div style="font-size: 48px; margin-bottom: 16px;">&#128221;</div>
                <h3 style="color: #666;">No practice logs yet</h3>
                <p style="color: #999;">Start tracking your project progress!</p>
            </div>
        </div>

        <!-- Sidebar -->
        <div>
            <!-- Project Progress -->
            <div style="background: white; border-radius: 12px; padding: 20px; margin-bottom: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                <h3 style="margin: 0 0 16px 0; color: #333;">Project Progress</h3>
                <div style="text-align: center; margin-bottom: 16px;">
                    <div style="font-size: 48px; font-weight: bold; color: #667eea;" tal:content="python: str(context.progress) + '%'">0%</div>
                </div>
                <div style="background: #e0e0e0; border-radius: 4px; height: 12px; overflow: hidden;">
                    <div style="width: ${context/progress}%; background: linear-gradient(90deg, #667eea, #764ba2); height: 100%;"></div>
                </div>
            </div>

            <!-- Milestones -->
            <div style="background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                    <h3 style="margin: 0; color: #333;">Milestones</h3>
                    <a href="${request/resource_url(context)}/@@milestones" style="font-size: 14px; color: #667eea;">View All</a>
                </div>
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    <tal:block tal:repeat="milestone milestones">
                        <div style="padding: 12px; background: #f8f9fa; border-radius: 8px;">
                            <div style="font-weight: 500;" tal:content="milestone/title">Milestone</div>
                            <div style="font-size: 12px; color: #666; margin-top: 4px;">
                                <span tal:content="milestone/get_status_display">Status</span>
                                <tal:block tal:condition="milestone/target_date">
                                    | <span tal:define="from datetime import datetime; ts python: datetime.fromtimestamp(milestone.target_date)" tal:content="python: ts.strftime('%Y-%m-%d')">Date</span>
                                </tal:block>
                            </div>
                        </div>
                    </tal:block>
                </div>
                <p tal:condition="not:milestones" style="color: #999; margin: 0;">No milestones defined</p>
            </div>
        </div>
    </div>
</div>
</tal:block>

</html>
