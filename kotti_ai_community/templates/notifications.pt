<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      metal:use-macro="api.macro('kotti:templates/view/master.pt')">

<tal:block metal:fill-slot="content">
<div class="notifications-page" style="max-width: 800px; margin: 0 auto; padding: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h1 style="margin: 0;">Notifications</h1>
        <tal:block tal:condition="python: unread_count > 0">
            <a href="?mark_all_read=1" style="background: #667eea; color: white; padding: 8px 16px; border-radius: 8px; text-decoration: none; font-size: 14px;">
                Mark all as read
            </a>
        </tal:block>
    </div>

    <!-- Unread count badge -->
    <div tal:condition="python: unread_count > 0" style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 12px 16px; margin-bottom: 24px;">
        You have <strong>${unread_count}</strong> unread notification(s)
    </div>

    <!-- Notifications List -->
    <div style="background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <tal:block tal:repeat="notification notifications">
            <div tal:attributes="style python: 'display: flex; padding: 16px 20px; border-bottom: 1px solid #f0f0f0; align-items: flex-start;' + (' background: #f0f7ff;' if not notification.is_read else '')">
                <!-- Icon -->
                <div style="width: 40px; height: 40px; border-radius: 50%; background: #667eea; display: flex; align-items: center; justify-content: center; color: white; margin-right: 16px; flex-shrink: 0;">
                    <tal:block tal:define="type_info python: notification_types.get(notification.notification_type, {})">
                        <span tal:content="python: type_info.get('icon', 'bell')[0].upper()" style="font-size: 18px; font-weight: bold;">N</span>
                    </tal:block>
                </div>

                <!-- Content -->
                <div style="flex: 1;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div>
                            <div style="font-weight: bold; font-size: 16px;" tal:content="notification/title">Title</div>
                            <div style="color: #666; font-size: 14px; margin-top: 4px;" tal:content="notification/message">Message</div>
                        </div>
                        <tal:block tal:condition="not:notification/is_read">
                            <span style="background: #667eea; color: white; padding: 2px 8px; border-radius: 10px; font-size: 11px;">NEW</span>
                        </tal:block>
                    </div>

                    <!-- Time and actions -->
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 12px;">
                        <div style="color: #999; font-size: 12px;" tal:content="python: notification.created.strftime('%Y-%m-%d %H:%M') if notification.created else ''">
                            Time
                        </div>
                        <div style="display: flex; gap: 12px;">
                            <tal:block tal:condition="notification/link">
                                <a tal:attributes="href notification/link" style="color: #667eea; text-decoration: none; font-size: 14px;">View</a>
                            </tal:block>
                            <tal:block tal:condition="not:notification/is_read">
                                <a href="?read=${notification/id}" style="color: #666; text-decoration: none; font-size: 14px;">Mark as read</a>
                            </tal:block>
                        </div>
                    </div>
                </div>
            </div>
        </tal:block>
    </div>

    <!-- Empty State -->
    <div tal:condition="not:notifications" style="text-align: center; padding: 60px 20px; background: white; border-radius: 12px;">
        <div style="font-size: 48px; margin-bottom: 16px;">&#128276;</div>
        <h3 style="color: #666;">No notifications</h3>
        <p style="color: #999;">You're all caught up!</p>
    </div>
</div>
</tal:block>

</html>
